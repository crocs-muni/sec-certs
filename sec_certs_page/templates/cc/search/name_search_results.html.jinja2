{% from "cc/include.html.jinja2" import render_category, render_status %}
<div id="search-partial"
     data-sort-by="{{ sort_by or '' }}"
     data-sort-dir="{{ sort_dir or '' }}"
     data-errors='{{ errors|tojson }}'>

    <div id="pagination-top-wrapper"
         class="d-flex flex-column align-items-center gap-1 {% if not result %}invisible{% endif %}">
        <span id="pagination-info" class="text-muted small">{{ pagination.info }}</span>
        <div id="pagination-links-top">{{ pagination.links }}</div>
    </div>

    <table hidden><tbody id="results-body">
        {% if result %}
            {% for cert in result %}
                {% set idd = cert["cert_id"]|default("", true) %}
                {% set name = cert["name"] %}
                {% set status = cert["status"] %}
                {% set hashid = cert["dgst"] %}
                {% set cert_date = cert["not_valid_before"] %}
                {% set archive_date = cert["not_valid_after"] %}
                {% set category = cert["category"] %}
                {% set scheme = cert["scheme"] %}
                {% set manufacturer = cert["manufacturer"] %}
                {% set cert_lab = cert["cert_lab"] %}
                <tr class="search-result{% if cert.get('snippets') %} has-snippets{% endif %}">
                    <td data-col="cert_id" class="text-nowrap">
                        <span class="result-category">{{ render_category(category) }}</span>&nbsp;<span class="result-id ">{{ idd }}</span>
                    </td>
                    <td data-col="name">
                        <a href="{{ url_for('.entry', hashid=hashid) }}"
                           class="result-clamp result-link text-decoration-none fw-medium"
                           data-bs-toggle="tooltip"
                           data-bs-placement="top">{{ name }}</a>
                        {% if cert.get("snippets") %}
                        {% set doc_type_labels = {"cert": "Certificate", "report": "Evaluation Report", "target": "Security Target"} %}
                        <div class="d-flex flex-column mt-2 gap-1">
                            {% for doc_type, snippet_html in cert["snippets"].items() %}
                            <div>
                                <div class="snippet-label">[{{ doc_type_labels.get(doc_type, doc_type) }}]</div>
                                <div class="snippet-text">{{ snippet_html|safe }}</div>
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}
                    </td>
                    <td data-col="manufacturer"><div class="result-clamp" data-bs-toggle="tooltip" data-bs-placement="top">{{ manufacturer }}</div></td>
                    <td data-col="cert_lab" class="">{{ cert_lab }}</td>
                    <td data-col="scheme">{{ country_to_flag(scheme) }} {{ scheme }}</td>
                    <td data-col="eal" class="text-nowrap">{{ cert.get("eal") or "" }}</td>
                    <td data-col="status">{{ render_status(status) }}</td>
                    <td data-col="not_valid_before" class="text-nowrap">{{ cert_date|strftime("%d.%m.%Y") if cert_date else "" }}</td>
                    <td data-col="not_valid_after" class="text-nowrap">{{ archive_date|strftime("%d.%m.%Y") if archive_date else "" }}</td>
                </tr>
            {% endfor %}
        {% else %}
            <tr>
                <td colspan="9" class="text-center text-muted py-5">
                    <i class="fas fa-search fa-2x mb-2 d-block opacity-25"></i>
                    No results found.
                </td>
            </tr>
        {% endif %}
    </tbody></table>

    <div id="pagination-bottom-wrapper"
         class="mt-3 mb-4 d-flex flex-column align-items-center gap-1 {% if not result %}invisible{% endif %}">
        <div id="pagination-links-bottom">{{ pagination.links }}</div>
        <span id="pagination-info-bottom" class="text-muted small">{{ pagination.info }}</span>
    </div>
</div>
