{% extends "common/base.html.jinja2" %}
{% from "include/keyword_filter.html.jinja2" import keyword_filter %}

{% block head %}
    {{ super() }}
    <link rel="stylesheet" href="{{ url_for('static', filename='year_range_slider.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='keyword_tree.css') }}">
{% endblock %}

{% block content %}
    <main>
        <div class="alert alert-warning d-sm-none" role="alert">
            <i class="fas fa-exclamation-triangle"></i> This page was not yet optimized for use on mobile devices.
        </div>
        <div class="container-lg px-3 px-md-4 pt-4">
            <div class="d-flex align-items-baseline gap-2 mb-3">
                <h1>FIPS 140</h1>
                <span class="text-secondary fs-3">Search</span>
            </div>
            <div class="card shadow-sm mb-4">
                <div class="card-body p-3 p-md-4">
                    <fieldset class="mb-3 border-0 p-0">
                        <legend class="fw-semibold fs-6 mb-2">Search type</legend>
                        <div class="d-flex flex-wrap gap-3">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="radio" name="searchTypeRadio"
                                       id="nameSearchRadioId" value="by-name"
                                       {% if search_type == "name" %}checked{% endif %}>
                                <label class="form-check-label" for="nameSearchRadioId">
                                    Name search
                                </label>
                                <i class="fa fa-info-circle ms-1 text-muted"
                                   data-bs-toggle="tooltip"
                                   data-bs-title="Search only in certificate names"
                                   aria-hidden="true"></i>
                            </div>
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="radio" name="searchTypeRadio"
                                       id="fulltextSearchRadioId" value="fulltext"
                                       {% if search_type == "fulltext" %}checked{% endif %}>
                                <label class="form-check-label" for="fulltextSearchRadioId">
                                    Fulltext search
                                </label>
                                <i class="fa fa-info-circle ms-1 text-muted"
                                   data-bs-toggle="tooltip"
                                   data-bs-title="Search within the entire content of certificate PDFs"
                                   aria-hidden="true"></i>
                            </div>
                        </div>
                    </fieldset>

                    <div class="d-flex gap-2 align-items-center">
                        <label for="search" class="visually-hidden">Search query</label>
                        <input id="search"
                               data-param="query"
                               data-feedback="query-error"
                               class="form-control flex-grow-1 {% if errors.query %}is-invalid{% endif %}"
                               placeholder="Search prompt"
                               type="search"
                               aria-describedby="query-error"
                               value="{{ query|default('', true) }}"/>
                        <button type="button" id="search-btn" class="btn btn-primary flex-shrink-0">
                            <i class="fas fa-search me-1"></i>Search
                        </button>
                        <button id="extended-btn"
                                class="btn btn-outline-secondary flex-shrink-0 d-inline-flex align-items-center gap-1"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#extended"
                                aria-controls="extended"
                                aria-expanded="{% if advanced %}true{% else %}false{% endif %}">
                            <i class="fas fa-sliders"></i>
                            <span class="d-none d-sm-inline">Advanced search</span>
                        </button>
                    </div>
                    <div id="query-error" class="invalid-feedback d-block" role="alert" aria-live="polite">
                        {% for error in errors.query %}<div>{{ error }}</div>{% endfor %}
                    </div>
                    <div class="mt-1">
                        <a href="{{ url_for('query_guide') }}" class="text-muted small" target="_blank">
                            <i class="fas fa-book me-1"></i>Query syntax guide
                        </a>
                    </div>
                    <div id="extended" class="collapse {% if advanced %}show{% endif %} mt-3">
                        <hr class="mt-0 mb-3">
                        <div class="row g-3" id="filter-fields-desktop">
                            <div class="col-12 col-md-4 col-lg-3 fulltext-only">
                                <label class="form-label fw-semibold mb-1" for="name">Name</label>
                                <input id="name" type="text"
                                       data-param="name"
                                       data-feedback="name-error"
                                       class="form-control {% if errors.name %}is-invalid{% endif %}"
                                       placeholder="e.g. Apple"
                                       value="{{ name|default('', true) }}">
                                <div id="name-error" class="invalid-feedback">
                                    {% for error in errors.name %}<div>{{ error }}</div>{% endfor %}
                                </div>
                            </div>
                            <div class="col-12 col-md-4 col-lg-3">
                                <label class="form-label fw-semibold mb-1" for="cert-id">Cert ID</label>
                                <input id="cert-id" type="text"
                                       data-param="cert_id"
                                       data-feedback="cert-id-error"
                                       class="form-control {% if errors.cert_id %}is-invalid{% endif %}"
                                       placeholder="e.g. 1747"
                                       value="{{ cert_id|default('', true) }}">
                                <div id="cert-id-error" class="invalid-feedback">
                                    {% for error in errors.cert_id %}<div>{{ error }}</div>{% endfor %}
                                </div>
                            </div>
                            <div class="col-12 col-md-4 col-lg-3">
                                <label class="form-label fw-semibold mb-1" for="vendor">Vendor</label>
                                <input id="vendor" type="text"
                                       data-param="vendor"
                                       data-feedback="vendor-error"
                                       class="form-control {% if errors.vendor %}is-invalid{% endif %}"
                                       placeholder="e.g. Red Hat"
                                       value="{{ vendor|default('', true) }}">
                                <div id="vendor-error" class="invalid-feedback">
                                    {% for error in errors.vendor %}<div>{{ error }}</div>{% endfor %}
                                </div>
                            </div>
                            <div class="col-12 col-md-4 col-lg-3">
                                <div id="status-container">
                                    <label class="form-label fw-semibold mb-1 d-block" for="status-dropdown-btn">Status</label>
                                    <div class="dropdown">
                                        <button class="form-select text-start w-100" type="button"
                                                id="status-dropdown-btn"
                                                data-bs-toggle="dropdown"
                                                data-bs-auto-close="outside"
                                                aria-haspopup="true"
                                                aria-expanded="false"
                                                aria-label="Status: {{ status|capitalize if status else 'Any' }}">
                                            <span id="status-label">{{ status|capitalize if status else 'Any' }}</span>
                                        </button>
                                        <ul class="dropdown-menu" role="group" aria-labelledby="status-dropdown-btn" style="min-width: 140px;">
                                            <li><h6 class="dropdown-header" id="status-menu-header">Select status</h6></li>
                                            {% for val, label in [('', 'Any'), ('active', 'Active'), ('historical', 'Historical'), ('revoked', 'Revoked')] %}
                                            <li role="none">
                                                <label class="dropdown-item d-flex align-items-center gap-2" role="menuitemradio"
                                                       aria-checked="{{ 'true' if (status == val or (not status and val == '')) else 'false' }}">
                                                    <input type="radio" name="status-radio"
                                                           class="form-check-input status-radio"
                                                           value="{{ val }}"
                                                           {% if status == val or (not status and val == '') %}checked{% endif %}>
                                                    {{ label }}
                                                </label>
                                            </li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                    <input type="hidden" id="search-status" data-param="status" value="{{ status|default('', true) }}">
                                </div>
                            </div>
                            <div class="col-12 col-lg-6" role="group" aria-labelledby="validation-date-legend">
                                <span id="validation-date-legend" class="form-label fw-semibold mb-1 d-block">Validation date</span>
                                <div class="d-flex gap-1 align-items-center">
                                    <label class="visually-hidden" for="validation-date-from">Validation date from</label>
                                    <input id="validation-date-from" type="date" class="form-control"
                                           data-param="validation_date_from" data-range="validation-date"
                                           value="{{ validation_date_from.strftime('%Y-%m-%d') if validation_date_from else '' }}">
                                    <span class="text-muted small flex-shrink-0" aria-hidden="true">–</span>
                                    <label class="visually-hidden" for="validation-date-to">Validation date to</label>
                                    <input id="validation-date-to" type="date" class="form-control"
                                           data-param="validation_date_to" data-range="validation-date"
                                           value="{{ validation_date_to.strftime('%Y-%m-%d') if validation_date_to else '' }}">
                                </div>
                                <div class="year-range-slider mt-2" data-from="validation-date-from" data-to="validation-date-to" data-min-year="1997"></div>
                                <div id="validation-date-error" class="invalid-feedback" role="alert"></div>
                            </div>
                            <div class="col-12 col-lg-6" role="group" aria-labelledby="sunset-date-legend">
                                <span id="sunset-date-legend" class="form-label fw-semibold mb-1 d-block">Sunset date</span>
                                <div class="d-flex gap-1 align-items-center">
                                    <label class="visually-hidden" for="sunset-date-from">Sunset date from</label>
                                    <input id="sunset-date-from" type="date" class="form-control"
                                           data-param="sunset_date_from" data-range="sunset-date"
                                           value="{{ sunset_date_from.strftime('%Y-%m-%d') if sunset_date_from else '' }}">
                                    <span class="text-muted small flex-shrink-0" aria-hidden="true">–</span>
                                    <label class="visually-hidden" for="sunset-date-to">Sunset date to</label>
                                    <input id="sunset-date-to" type="date" class="form-control"
                                           data-param="sunset_date_to" data-range="sunset-date"
                                           value="{{ sunset_date_to.strftime('%Y-%m-%d') if sunset_date_to else '' }}">
                                </div>
                                <div class="year-range-slider mt-2" data-from="sunset-date-from" data-to="sunset-date-to" data-max-year="2040"></div>
                                <div id="sunset-date-error" class="invalid-feedback" role="alert"></div>
                            </div>
                            <div class="col-12 col-md-4 col-lg-3">
                                <label class="form-label fw-semibold mb-1 d-block" for="categories-dropdown-btn">Categories</label>
                                <div class="dropdown">
                                    <button class="form-select text-start w-100" type="button"
                                            id="categories-dropdown-btn"
                                            data-bs-toggle="dropdown"
                                            data-bs-auto-close="outside"
                                            aria-haspopup="true"
                                            aria-expanded="false">
                                        <span>Categories</span>
                                        <span id="categories-badge" class="badge bg-secondary ms-1" aria-label="{{ selected_categories.values()|selectattr('selected')|list|length }} selected">{{ selected_categories.values()|selectattr("selected")|list|length }}</span>
                                    </button>
                                    <ul class="dropdown-menu" role="group" aria-labelledby="categories-dropdown-btn">
                                        <li><h6 class="dropdown-header" id="categories-menu-header">Select categories</h6></li>
                                        <li>
                                            <div id="search-categories" data-search-group data-param="cat" data-encoding="concat">
                                                {% for name, val in selected_categories.items() %}
                                                    <label class="dropdown-item d-flex align-items-center gap-2" for="category-{{ val['id'] }}">
                                                        <input type="checkbox" id="category-{{ val['id'] }}"
                                                               class="form-check-input"
                                                               data-id="{{ val['id'] }}"
                                                               {% if val["selected"] %}checked{% endif %}>
                                                        <i class="fas fa-fw {{ val['icon'] }}" aria-hidden="true"></i> {{ name }}
                                                    </label>
                                                {% endfor %}
                                            </div>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li class="d-flex justify-content-between px-3">
                                            <button class="btn btn-link btn-sm p-0" id="cat-select-all" data-group-action="select">Select all</button>
                                            <button class="btn btn-link btn-sm p-0" id="cat-deselect-all" data-group-action="deselect">Deselect all</button>
                                        </li>
                                    </ul>
                                </div>
                                <div id="categories-error" class="invalid-feedback" role="alert"></div>
                            </div>
                            <div class="col-12 col-md-4 col-lg-3">
                                <label class="form-label fw-semibold mb-1 d-block" for="levels-dropdown-btn">Security level</label>
                                <div class="dropdown">
                                    <button class="form-select text-start w-100" type="button"
                                            id="levels-dropdown-btn"
                                            data-bs-toggle="dropdown"
                                            data-bs-auto-close="outside"
                                            aria-haspopup="true"
                                            aria-expanded="false">
                                        <span>Levels</span>
                                        <span id="levels-badge" class="badge bg-secondary ms-1" aria-label="{{ selected_levels|length }} selected">{{ selected_levels|length }}</span>
                                    </button>
                                    <ul class="dropdown-menu" role="group" aria-labelledby="levels-dropdown-btn" style="min-width: 220px">
                                        <li><h6 class="dropdown-header" id="levels-menu-header">Select levels</h6></li>
                                        <li>
                                            <div id="search-levels" data-search-group data-param="level" data-encoding="bitmask">
                                                {% for key, val in all_levels.items()|sort %}
                                                    <label class="dropdown-item d-flex align-items-center gap-2" for="level-{{ key }}">
                                                        <input type="checkbox" id="level-{{ key }}"
                                                               class="form-check-input"
                                                               {% if key in selected_levels %}checked{% endif %}>
                                                        <span class="fw-medium">{{ val.name }}</span>
                                                    </label>
                                                {% endfor %}
                                            </div>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li class="d-flex justify-content-between px-3">
                                            <button class="btn btn-link btn-sm p-0" id="levels-select-all" data-group-action="select">Select all</button>
                                            <button class="btn btn-link btn-sm p-0" id="levels-deselect-all" data-group-action="deselect">Deselect all</button>
                                        </li>
                                    </ul>
                                </div>
                                <div id="levels-error" class="invalid-feedback" role="alert"></div>
                            </div>
                            {{ keyword_filter("fips", [], keywords, [], kw_mode) }}
                        </div>
                        <div class="mt-3">
                            <button type="button" id="reset-filters-btn"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Reset all to their default values."
                                    data-bs-toggle="tooltip">
                                <i class="fas fa-rotate-left me-1"></i>Reset
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script type="module">
            import { initSearch } from "{{ url_for('static', filename='search.js') }}?{{ static_hash("search.js") }}";
            import { initKeywordTree } from "{{ url_for('static', filename='keyword_tree.js') }}?{{ static_hash("keyword_tree.js") }}";

            initKeywordTree();
            initSearch({
                searchUrl: "{{ url_for("fips.merged_search") }}",
                networkUrl: "{{ url_for("fips.network") }}",
            });
        </script>

        {% block search_content %}{% endblock %}
    </main>
{% endblock %}