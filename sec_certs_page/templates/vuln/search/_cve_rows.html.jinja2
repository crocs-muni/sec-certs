{% from "include/entry.html.jinja2" import render_cve_impact %}
{% if result %}
    {% for cve in result %}
        {% set cwe = cve.get("cwe") %}
        <tr class="search-result">
            <td data-col="cve_id" class="text-nowrap">
                <a href="{{ url_for('vuln.cve', cve_id=cve['id']) }}"
                   class="result-link text-decoration-none fw-medium">{{ cve["cve_id"] }}</a>
            </td>
            <td data-col="cwe">{% if cwe is string %}{{ cwe }}{% elif cwe %}{{ cwe|join(", ") }}{% endif %}</td>
            <td data-col="severity">{{ render_cve_impact(cve.get("severity")) }}</td>
            <td data-col="base_score" class="text-nowrap">{{ cve.get("base_score") }}</td>
            <td data-col="published_date" class="text-nowrap">{{ cve["published_date"]|strftime("%d.%m.%Y") if cve.get("published_date") else "" }}</td>
            <td data-col="cert_count" class="text-nowrap">{{ cve.get("cert_count") or 0 }}</td>
        </tr>
    {% endfor %}
{% else %}
    <tr>
        <td colspan="6" class="text-center text-muted py-5">
            <i class="fas fa-search fa-2x mb-2 d-block opacity-25"></i>
            No results found.
        </td>
    </tr>
{% endif %}
