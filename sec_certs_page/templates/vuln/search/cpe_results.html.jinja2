<div id="search-partial"
     data-sort-by="{{ sort_by or '' }}"
     data-sort-dir="{{ sort_dir or '' }}"
     data-errors='{{ errors|tojson }}'>

    <div id="pagination-top-wrapper"
         class="d-flex flex-column align-items-center gap-1 {% if not result %}invisible{% endif %}">
        <span id="pagination-info" class="text-muted small">{{ pagination.info }}</span>
        <div id="pagination-links-top">{{ pagination.links }}</div>
    </div>

    <table hidden><tbody id="results-body">
        {% include "vuln/search/_cpe_rows.html.jinja2" %}
    </tbody></table>

    <div id="pagination-bottom-wrapper"
         class="mt-3 mb-4 d-flex flex-column align-items-center gap-1 {% if not result %}invisible{% endif %}">
        <div id="pagination-links-bottom">{{ pagination.links }}</div>
        <span id="pagination-info-bottom" class="text-muted small">{{ pagination.info }}</span>
    </div>
</div>
