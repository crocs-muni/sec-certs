{% extends "common/base.html.jinja2" %}
{% from "include/keyword_filter.html.jinja2" import keyword_filter %}

{% block head %}
    {{ super() }}
    <link rel="stylesheet" href="{{ url_for('static', filename='range_slider.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='keyword_tree.css') }}">
{% endblock %}

{% block content %}
    <main>
        <div class="alert alert-warning d-sm-none" role="alert">
            <i class="fas fa-exclamation-triangle"></i> This page was not yet optimized for use on mobile devices.
        </div>
        <div class="container-lg px-3 px-md-4 pt-4">
            <div class="d-flex align-items-baseline gap-2 mb-3">
                <h1>EUCC</h1>
                <span class="text-secondary fs-3">Search</span>
            </div>
            <div class="card shadow-sm mb-4">
                <div class="card-body p-3 p-md-4">
                    <fieldset class="mb-3 border-0 p-0">
                        <legend class="fw-semibold fs-6 mb-2">Search type</legend>
                        <div class="d-flex flex-wrap gap-3">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="radio" name="searchTypeRadio"
                                       id="nameSearchRadioId" value="by-name"
                                       {% if search_type == "name" %}checked{% endif %}>
                                <label class="form-check-label" for="nameSearchRadioId">
                                    Name search
                                </label>
                                <i class="fa fa-info-circle ms-1 text-muted"
                                   data-bs-toggle="tooltip"
                                   data-bs-title="Search only in certificate names"
                                   aria-hidden="true"></i>
                            </div>
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="radio" name="searchTypeRadio"
                                       id="fulltextSearchRadioId" value="fulltext"
                                       {% if search_type == "fulltext" %}checked{% endif %}>
                                <label class="form-check-label" for="fulltextSearchRadioId">
                                    Fulltext search
                                </label>
                                <i class="fa fa-info-circle ms-1 text-muted"
                                   data-bs-toggle="tooltip"
                                   data-bs-title="Search within the entire content of certificate PDFs"
                                   aria-hidden="true"></i>
                            </div>
                        </div>
                    </fieldset>

                    <div class="d-flex gap-2 align-items-center">
                        <label for="search" class="visually-hidden">Search query</label>
                        <input id="search"
                               data-param="query"
                               data-feedback="query-error"
                               class="form-control flex-grow-1 {% if errors.query %}is-invalid{% endif %}"
                               placeholder="Search prompt"
                               type="search"
                               aria-describedby="query-error"
                               value="{{ query|default('', true) }}"/>
                        <button type="button" id="search-btn" class="btn btn-primary flex-shrink-0">
                            <i class="fas fa-search me-1"></i>Search
                        </button>
                        <button id="extended-btn"
                                class="btn btn-outline-secondary flex-shrink-0 d-inline-flex align-items-center gap-1"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#extended"
                                aria-controls="extended"
                                aria-expanded="{% if advanced %}true{% else %}false{% endif %}">
                            <i class="fas fa-sliders"></i>
                            <span class="d-none d-sm-inline">Advanced search</span>
                        </button>
                    </div>
                    <div id="query-error" class="invalid-feedback d-block" role="alert" aria-live="polite">
                        {% for error in errors.query %}<div>{{ error }}</div>{% endfor %}
                    </div>
                    <div class="mt-1">
                        <a href="{{ url_for('query_guide') }}" class="text-muted small" target="_blank">
                            <i class="fas fa-book me-1"></i>Query syntax guide
                        </a>
                    </div>
                    <div id="extended" class="collapse {% if advanced %}show{% endif %} mt-3">
                        <hr class="mt-0 mb-3">
                        <div class="row g-3" id="filter-fields-desktop">
                            <div class="col-12 col-md-4 col-lg-3 fulltext-only">
                                <label class="form-label fw-semibold mb-1" for="name">Name</label>
                                <input id="name" type="text"
                                       data-param="name"
                                       data-feedback="name-error"
                                       class="form-control {% if errors.name %}is-invalid{% endif %}"
                                       placeholder="e.g. Apple"
                                       value="{{ name|default('', true) }}">
                                <div id="name-error" class="invalid-feedback">
                                    {% for error in errors.name %}<div>{{ error }}</div>{% endfor %}
                                </div>
                            </div>
                            <div class="col-12 col-md-4 col-lg-3">
                                <label class="form-label fw-semibold mb-1" for="cert-id">Cert ID</label>
                                <input id="cert-id" type="text"
                                       data-param="cert_id"
                                       data-feedback="cert-id-error"
                                       class="form-control {% if errors.cert_id %}is-invalid{% endif %}"
                                       placeholder="e.g. ANSSI"
                                       value="{{ cert_id|default('', true) }}">
                                <div id="cert-id-error" class="invalid-feedback">
                                    {% for error in errors.cert_id %}<div>{{ error }}</div>{% endfor %}
                                </div>
                            </div>
                            <div class="col-12 col-md-4 col-lg-3">
                                <div id="status-container">
                                    <label class="form-label fw-semibold mb-1 d-block" for="status-dropdown-btn">Status</label>
                                    <div class="dropdown">
                                        <button class="form-select text-start w-100" type="button"
                                                id="status-dropdown-btn"
                                                data-bs-toggle="dropdown"
                                                data-bs-auto-close="outside"
                                                aria-haspopup="true"
                                                aria-expanded="false"
                                                aria-label="Status: {{ status|capitalize if status else 'Any' }}">
                                            <span id="status-label">{{ status|capitalize if status else 'Any' }}</span>
                                        </button>
                                        <ul class="dropdown-menu" role="group" aria-labelledby="status-dropdown-btn" style="min-width: 140px;">
                                            <li><h6 class="dropdown-header" id="status-menu-header">Select status</h6></li>
                                            {% for val, label in [('', 'Any'), ('active', 'Active'), ('archived', 'Archived')] %}
                                            <li role="none">
                                                <label class="dropdown-item d-flex align-items-center gap-2" role="menuitemradio"
                                                       aria-checked="{{ 'true' if (status == val or (not status and val == '')) else 'false' }}">
                                                    <input type="radio" name="status-radio"
                                                           class="form-check-input status-radio"
                                                           value="{{ val }}"
                                                           {% if status == val or (not status and val == '') %}checked{% endif %}>
                                                    {{ label }}
                                                </label>
                                            </li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                    <input type="hidden" id="search-status" data-param="status" value="{{ status|default('', true) }}">
                                </div>
                            </div>
                            <div class="w-100 mt-0"></div>
                            <div class="col-12 col-lg-6" role="group" aria-labelledby="cert-date-legend">
                                <span id="cert-date-legend" class="form-label fw-semibold mb-1 d-block">Certification date</span>
                                <div class="d-flex gap-1 align-items-center">
                                    <label class="visually-hidden" for="cert-date-from">Certification date from</label>
                                    <input id="cert-date-from" type="date" class="form-control"
                                           data-param="cert_date_from" data-range="cert-date"
                                           value="{{ cert_date_from.strftime('%Y-%m-%d') if cert_date_from else '' }}">
                                    <span class="text-muted small flex-shrink-0" aria-hidden="true">–</span>
                                    <label class="visually-hidden" for="cert-date-to">Certification date to</label>
                                    <input id="cert-date-to" type="date" class="form-control"
                                           data-param="cert_date_to" data-range="cert-date"
                                           value="{{ cert_date_to.strftime('%Y-%m-%d') if cert_date_to else '' }}">
                                </div>
                                <div class="range-slider mt-2" data-from="cert-date-from" data-to="cert-date-to" data-min-year="1997"></div>
                                <div id="cert-date-error" class="invalid-feedback" role="alert"></div>
                            </div>
                            <div class="col-12 col-lg-6" role="group" aria-labelledby="archive-date-legend">
                                <span id="archive-date-legend" class="form-label fw-semibold mb-1 d-block">Archive date</span>
                                <div class="d-flex gap-1 align-items-center">
                                    <label class="visually-hidden" for="archive-date-from">Archive date from</label>
                                    <input id="archive-date-from" type="date" class="form-control"
                                           data-param="archive_date_from" data-range="archive-date"
                                           value="{{ archive_date_from.strftime('%Y-%m-%d') if archive_date_from else '' }}">
                                    <span class="text-muted small flex-shrink-0" aria-hidden="true">–</span>
                                    <label class="visually-hidden" for="archive-date-to">Archive date to</label>
                                    <input id="archive-date-to" type="date" class="form-control"
                                           data-param="archive_date_to" data-range="archive-date"
                                           value="{{ archive_date_to.strftime('%Y-%m-%d') if archive_date_to else '' }}">
                                </div>
                                <div class="range-slider mt-2" data-from="archive-date-from" data-to="archive-date-to" data-max-year="2040"></div>
                                <div id="archive-date-error" class="invalid-feedback" role="alert"></div>
                            </div>
                            <div class="w-100 mt-0"></div>
                            <div class="col-12 col-md-4 col-lg-3">
                                <label class="form-label fw-semibold mb-1 d-block" for="schemes-dropdown-btn">Schemes</label>
                                <div class="dropdown">
                                    <button class="form-select text-start w-100" type="button"
                                            id="schemes-dropdown-btn"
                                            data-bs-toggle="dropdown"
                                            data-bs-auto-close="outside"
                                            aria-haspopup="true"
                                            aria-expanded="false">
                                        <span>Schemes</span>
                                        <span id="schemes-badge" class="badge bg-secondary ms-1" aria-label="{{ selected_schemes|length }} selected">{{ selected_schemes|length }}</span>
                                    </button>
                                    <ul class="dropdown-menu" role="group" aria-labelledby="schemes-dropdown-btn" style="min-width: 200px">
                                        <li><h6 class="dropdown-header" id="schemes-menu-header">Select schemes</h6></li>
                                        <li>
                                            <div id="search-schemes" data-search-group data-param="schemes" data-encoding="bitmask">
                                                {% for s in all_schemes|sort %}
                                                    <label class="dropdown-item d-flex align-items-center gap-2" for="scheme-{{ s }}">
                                                        <input type="checkbox" id="scheme-{{ s }}"
                                                               class="form-check-input"
                                                               {% if s in selected_schemes %}checked{% endif %}>
                                                        {{ country_to_flag(s) }} {{ s }}
                                                    </label>
                                                {% endfor %}
                                            </div>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li class="d-flex justify-content-between px-3">
                                            <button class="btn btn-link btn-sm p-0" id="schemes-select-all" data-group-action="select">Select all</button>
                                            <button class="btn btn-link btn-sm p-0" id="schemes-deselect-all" data-group-action="deselect">Deselect all</button>
                                        </li>
                                    </ul>
                                </div>
                                <div id="schemes-error" class="invalid-feedback" role="alert"></div>
                            </div>
                            <div class="col-12 col-md-4 col-lg-3">
                                <label class="form-label fw-semibold mb-1 d-block" for="eals-dropdown-btn">Evaluation Assurance Level</label>
                                <div class="dropdown">
                                    <button class="form-select text-start w-100" type="button"
                                            id="eals-dropdown-btn"
                                            data-bs-toggle="dropdown"
                                            data-bs-auto-close="outside"
                                            aria-haspopup="true"
                                            aria-expanded="false">
                                        <span>EAL</span>
                                        <span id="eals-badge" class="badge bg-secondary ms-1" aria-label="{{ selected_eals|length }} selected">{{ selected_eals|length }}</span>
                                    </button>
                                    <ul class="dropdown-menu" role="group" aria-labelledby="eals-dropdown-btn" style="min-width: 220px">
                                        <li><h6 class="dropdown-header" id="eals-menu-header">Select EAL levels</h6></li>
                                        <li>
                                            <div id="search-eals" data-search-group data-param="eal" data-encoding="bitmask">
                                                {% for key, val in all_eals.items()|sort %}
                                                    <label class="dropdown-item d-flex align-items-center gap-2" for="eal-{{ key }}">
                                                        <input type="checkbox" id="eal-{{ key }}"
                                                               class="form-check-input"
                                                               {% if key in selected_eals %}checked{% endif %}>
                                                        <span class="fw-medium">{{ key }}</span>
                                                        <span class="text-muted small">{{ val.name }}</span>
                                                    </label>
                                                {% endfor %}
                                            </div>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li class="d-flex justify-content-between px-3">
                                            <button class="btn btn-link btn-sm p-0" id="eals-select-all" data-group-action="select">Select all</button>
                                            <button class="btn btn-link btn-sm p-0" id="eals-deselect-all" data-group-action="deselect">Deselect all</button>
                                        </li>
                                    </ul>
                                </div>
                                <div id="eals-error" class="invalid-feedback" role="alert"></div>
                            </div>
                            {{ keyword_filter("eucc", [("cert", "Certificate"), ("report", "Certification report"), ("target", "Security target")], keywords, selected_kw_sources, kw_mode) }}
                        </div>
                        <div class="mt-3">
                            <button type="button" id="reset-filters-btn"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Reset all to their default values."
                                    data-bs-toggle="tooltip">
                                <i class="fas fa-rotate-left me-1"></i>Reset
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script type="module">
            import { initSearch } from "{{ url_for('static', filename='search.js') }}?{{ static_hash("search.js") }}";
            import { initKeywordTree } from "{{ url_for('static', filename='keyword_tree.js') }}?{{ static_hash("keyword_tree.js") }}";

            initKeywordTree();
            initSearch({
                searchUrl: "{{ url_for("eucc.merged_search") }}",
                networkUrl: "",
            });
        </script>

        <script type="module">
        import { initSearchResults } from "{{ url_for('static', filename='search_results.js') }}?{{ static_hash("search_results.js") }}";

        const ENDPOINT = "{{ url_for('eucc.merged_search') }}";
        const COLS = [
            { key: 'cert_id',          label: 'ID',                 defaultVisible: true  },
            { key: 'name',             label: 'Name',               defaultVisible: true  },
            { key: 'scheme',           label: 'Scheme',             defaultVisible: true  },
            { key: 'eal',              label: 'EAL',                defaultVisible: true  },
            { key: 'status',           label: 'Status',             defaultVisible: true  },
            { key: 'not_valid_before', label: 'Certification date', defaultVisible: true  },
            { key: 'not_valid_after',  label: 'Archive date',       defaultVisible: true  },
        ];

        $(function () {
            initSearchResults({
                endpoint: ENDPOINT,
                cols: COLS,
                storageKey: 'eucc-col-visibility',
                fieldMap: { query: "#search", name: "#name", cert_id: "#cert-id" },
                sortBy: "{{ sort_by or '' }}",
                sortDir: "{{ sort_dir or '' }}",
            });

            // initSortable clones the headers, so (re)initialize header tooltips and
            // keep clicks on the help icon from triggering a sort.
            document.querySelectorAll('th.sortable [data-bs-toggle="tooltip"]').forEach(el => {
                bootstrap.Tooltip.getInstance(el)?.dispose();
                new bootstrap.Tooltip(el);
                el.addEventListener('click', e => e.stopPropagation());
            });
        });
    </script>


 <div class="container-xl results-container px-3 px-md-5 pb-4">
     <div id="results" data-sort-by="{{ sort_by or '' }}" data-sort-dir="{{ sort_dir or '' }}">
        <div class="d-grid mt-3 mb-1" style="grid-template-columns: 1fr auto 1fr; align-items: end;">
            <div></div>
            <div id="pagination-top-wrapper" class="d-flex flex-column align-items-center gap-1 {% if not result %}invisible{% endif %}">
                <span id="pagination-info" class="text-muted small">{{ pagination.info }}</span>
                <div id="pagination-links-top">{{ pagination.links }}</div>
            </div>

            <div class="d-flex justify-content-end">
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                            type="button"
                            id="col-picker-toggle"
                            data-bs-toggle="dropdown"
                            data-bs-auto-close="outside"
                            aria-expanded="false">
                        <i class="fas fa-columns me-1"></i>Visible columns
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" id="col-dropdown" style="min-width: 200px;">
                        <li><h6 class="dropdown-header">Visible columns</h6></li>
                        <div id="col-list"></div>
                        <li><hr class="dropdown-divider"></li>
                        <li class="d-flex justify-content-between px-3">
                            <button class="btn btn-link btn-sm p-0" id="col-show-all">Show all</button>
                            <button class="btn btn-link btn-sm p-0" id="col-hide-all">Hide all</button>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="table-scroll-wrapper">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <colgroup>
                    <col data-col="cert_id"          style="width: 16ch">
                    <col data-col="name">
                    <col data-col="scheme"           style="width: 6ch">
                    <col data-col="eal"              style="width: 8ch">
                    <col data-col="status"           style="width: 11ch">
                    <col data-col="not_valid_before" style="width: 11ch">
                    <col data-col="not_valid_after"  style="width: 11ch">
                </colgroup>
                <thead class="table-light">
                    <tr>
                        <th class="sortable" data-col="cert_id" title="Certificate ID"><span class="th-label">ID</span>
                            <span class="text-muted ms-1" style="cursor: help;" role="img" tabindex="0"
                                  data-bs-toggle="tooltip" data-bs-html="true" data-bs-placement="right"
                                  title="<b>ID Format: EUCC-XXXX-YYYY-MM-SSSSS-VV</b><br><br>&bull; <b>EUCC:</b> Scheme name<br>&bull; <b>XXXX:</b> Certification body ID<br>&bull; <b>YYYY:</b> Year of issuance<br>&bull; <b>S:</b> Unique serial number for that year<br>&bull; <b>V:</b> Version/revision"><i class="fas fa-info-circle fa-xs"></i></span> <span class="sort-icon"></span></th>
                        <th class="sortable" data-col="name" title="Certificate name"><span class="th-label">Name</span> <span class="sort-icon"></span></th>
                        <th class="sortable" data-col="scheme" title="Scheme"><span class="th-label">Scheme</span> <span class="sort-icon"></span></th>
                        <th class="sortable" data-col="eal" title="Assurance level"><span class="th-label">EAL</span><span class="sort-icon"></span></th>
                        <th class="sortable" data-col="status" title="Status"><span class="th-label">Status</span><span class="sort-icon"></span></th>
                        <th class="sortable" data-col="not_valid_before" data-default-sort="true" title="Certification date"><span class="th-label">Cert. date</span> <span class="sort-icon"></span></th>
                        <th class="sortable" data-col="not_valid_after" title="Archive date"><span class="th-label">Archive date</span> <span class="sort-icon"></span></th>
                    </tr>
                </thead>
                <tbody id="results-body">
                    {% include "eucc/search/_search_rows.html.jinja2" %}
                </tbody>
            </table>
        </div>
        </div>
        <div id="pagination-bottom-wrapper" class="mt-3 mb-4 d-flex flex-column align-items-center gap-1 {% if not result %}invisible{% endif %}">
            <div id="pagination-links-bottom">{{ pagination.links }}</div>
            <span id="pagination-info-bottom" class="text-muted small">{{ pagination.info }}</span>
        </div>
    </div>
 </div>
    </main>
{% endblock %}
