{% extends "eucc/search/base.html.jinja2" %}

{% from "cc/include.html.jinja2" import render_category, render_plot, render_status %}

{% block search_content %}
    <div class="col-12 col-sm-11 mx-auto p-3 py-md-5">
        <script type="module">
            import {
                nameSearchSetup,
            } from "/static/search.js?{{ static_hash("search.js") }}";

            $(function () {
                nameSearchSetup();
            })
        </script>

        <div id="results">
            <div id="pagination" class="table-responsive">
                <span style="text-align: center">{{ pagination.info }}</span>
                <div class="mt-4 mb-4">
                    {{ pagination.links }}
                </div>
                <table class="table table-striped table-bordered mb-4">
                    <col style="width:5%">
                    <col style="width:30%">
                    <col style="width:56%">
                    <col style="width:6%">
                    <col style="width:8%">
                    <col style="width:8%">
                    <thead>
                    <tr class="border-bottom">
                        <th>Issuing country</th>
                        <th class="pl-1">Certificate ID
                            <span class="text-muted ms-1 d-inline-flex align-items-center"
                                          style="cursor: help;"
                                          role="img"
                                          tabindex="0"
                                          data-bs-toggle="tooltip"
                                          data-bs-html="true"
                                          data-bs-placement="right"
                                          title="<b>ID Format: EUCC-XXXX-YYYY-MM-SSSSS-VV</b><br><br>
                             • <b>EUCC:</b> Scheme name<br>
                             • <b>XXXX:</b> Certification body ID<br>
                             • <b>YYYY:</b> Year of issuance<br>
                             • <b>S:</b> Unique serial number for that year<br>
                             • <b>V:</b> Version/revision"
                            >
                        <i class="fas fa-info-circle fa-xs"></i>
                    </span></th>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Certificationdate</th>
                        <th>Archive date</th>
                    </tr>
                    </thead>
                    {% for cert in certs %}
                        {% set idd = cert["cert_id"]|default("", true) %}
                        {% set name = cert["name"] %}
                        {% set status = cert["status"] %}
                        {% set hashid = cert["_id"] %}
                        {% set cert_date = cert["not_valid_before"] %}
                        {% set archive_date = cert["not_valid_after"] %}
                        {% set scheme = cert["scheme"] %}
                        <tr class="search-result">
                            <td class="text-center align-middle"><span
                                    class="result-scheme">{{ country_to_flag(scheme) }}</span></td>
                            <td class="pl-1"><span
                                    class="result-id">{{ idd | replace("CERTIFICATE ", "") }}</span></td>
                            <td><span class="result-name"><a href="{{ url_for('.entry', hashid=hashid) }}"
                                                             class="result-link">{{ name }}</a></span></td>
                            <td><span class="result-status">{{ render_status(status) }}</span></td>
                            <td><span
                                    class="result-cert-date">{{ cert_date|strftime("%d.%m.%Y") if cert_date else "" }}</span>
                            </td>
                            <td><span
                                    class="result-archive-date">{{ archive_date|strftime("%d.%m.%Y") if archive_date else "" }}</span>
                            </td>
                        </tr>
                    {% endfor %}
                </table>
                <div class="mb-4">
                    {{ pagination.links }}
                </div>
            </div>
            {{ render_plot(timeline) }}
        </div>
    </div>
{% endblock %}