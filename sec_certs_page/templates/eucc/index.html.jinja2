{% extends "common/base.html.jinja2" %}
{% set canonical = True %}
{% block title %}
    <title>EUCC | sec-certs.org</title>
{% endblock %}

{% block content %}
    <main>
        <div class="col-12 col-sm-10 mx-auto p-3 py-md-5">
            <div class="row mb-3 g-4 justify-content-start row-cols-1 row-cols-lg-2">
                <div class="col-sm-10 col-md-5 order-1 order-md-0">
                    <h1>EUCC</h1>
                    <h5 class="mb-4">EU Cybersecurity Certification Scheme on Common
                        Criteria</h5>
                    <p class="lead">
                        All the certificates are sourced from the EUCC portal at
                        <a href="https://certification.enisa.europa.eu/"
                           target="_blank">certification.enisa.europa.eu</a>.
                        The site provides certificates, each accompanied by a metadata table. These listings, along with
                        associated artifacts such as reports, security targets, and the certificates themselves, were
                        scraped to gather the data provided here.
                    </p>
                </div>
                <div class="col-5 d-flex justify-content-md-center align-items-md-center order-0 order-md-1">
                    <img src="{{ url_for("static", filename="img/eucc_logo.svg") }}" alt="sec-certs"
                         class="part-logo"
                         style="width: 10em"/>
                </div>
            </div>
        </div>

        <div class="row bg-darker-light p-3">
            <div class="col-12 col-sm-10 mx-auto">
                <div class="row my-5">
                    <div class="col-12 col-md-6">
                        <div class="feature-icon bg-primary bg-gradient">
                            <i class="fas fa-search fa-fw"></i>
                        </div>
                        <h3>Search</h3>
                        <p>We are converting all EUCC certificates from PDFs into machine readable format.
                            You can use this website to
                            search in our database for any EUCC certificate, discover its extracted metadata,
                            filter them and do much more.</p>
                        <a href="{{ url_for(".merged_search") }}" class="btn btn-primary">
                            Learn more <i class="fa-solid fa-arrow-right"></i>
                        </a>
                    </div>
                    <div class="col-12 col-md-6 mt-4 mt-md-0">
                        <div class="feature-icon bg-primary bg-gradient">
                            <i class="fa fa-lightbulb" aria-hidden="true"></i>
                        </div>
                        <h3>Example</h3>
                        <p>No more talking. Have a look at the example certificate we have chosen for you. Discover
                            extracted metadata and much more.
                            Don't forget to search for your own certificates later!</p>

                        <a href="{{ url_for("eucc.rand") }}" class="btn btn-outline-primary m-1 ms-0">
                            Random certificate
                        </a>
                        <a href="{{ url_for("eucc.entry", hashid="5446f38f4b9c9869") }}" class="btn btn-primary m-1">
                            Show example <i class="fa-solid fa-arrow-right"></i>
                        </a>

                    </div>
                </div>
            </div>
        </div>
        <div class="row p-3">
            <div class="col-12 col-sm-10 mx-auto">
                <div class="row my-5">
                    <div class="col-12 col-md-6">
                        <div class="feature-icon bg-primary bg-gradient">
                            <i class="fas fa-file-alt fa-fw"></i>
                        </div>
                        <h3>Data</h3>
                        <p>Want to process all EUCC data on your own? Download our prepared datasets and
                            analyse them.</p>
                        <a href="{{ url_for(".data") }}" class="btn btn-primary">
                            Learn more <i class="fa-solid fa-arrow-right"></i>
                        </a>
                    </div>

                </div>
            </div>
        </div>

    </main>
{% endblock %}
